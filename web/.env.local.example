# ─── Sanity ───────────────────────────────────────────────────────────────────
# Find these in sanity.io → your project → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Create a token in sanity.io → your project → Settings → API → Tokens
# Give it "Editor" permissions so it can write AI captions back
SANITY_WRITE_TOKEN=your_write_token_here

# Optional: lock down the webhook endpoint (Sanity → API → Webhooks → signing secret)
SANITY_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Anthropic (AI captions) ──────────────────────────────────────────────────
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Usage ────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.local.example .env.local
# 2. Fill in the values above
# 3. Never commit .env.local to git (it's already in .gitignore)
